{
  "name": "lintropy",
  "version": "0.1.2",
  "packageManager": "bun@1.3.6",
  "type": "module",
  "bin": {
    "lintropy": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun src/cli.ts",
    "download-model": "bun src/download.ts",
    "setup": "bun run download-model && bun run dev -- baseline",
    "lint:biome": "biome check .",
    "lint:eslint": "eslint .",
    "lint": "biome check . && eslint .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "check": "bun run lint && bun run typecheck && bun run knip",
    "test": "vitest run",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build",
    "prepare": "husky",
    "publish:local": "bun run scripts/publish-local.ts"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "Entropy linter for TypeScript vibe-coding issues.",
  "dependencies": {
    "@types/node": "^25.4.0",
    "commander": "^14.0.3",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
